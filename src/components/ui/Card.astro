---
const { isUnderline } = Astro.props;
---

{
  isUnderline ? (
    <div class="rounded-sm border border-dark shadow-[0px_5px_0px_#191a23] overflow-hidden">
    {/* // <div class="rounded-[15px]"> */}
      <slot />
    </div>
  ) : (
    <div class="rounded-[15px]">
      <slot />
    </div>
  )
}
