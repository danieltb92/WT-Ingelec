---
interface Props extends Record<string, any> {
  href?: string;
  variant?: "primary" | "secondary" | "tertiary" | "outline" | "ghost";
  size?: "sm" | "md" | "lg";
  class?: string;
  type?: "button" | "submit" | "reset";
  id?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  class: className,
  type = "button",
  id,
  ...rest
} = Astro.props;

const variants = {
  primary: "btn-primary",
  secondary: "btn-secondary",
  tertiary: "btn-tertiary",
  outline: "btn-outline",
  ghost: "btn-ghost",
};

const sizes = {
  sm: "btn-sm",
  md: "btn-md",
  lg: "btn-lg",
};

const variantClass = variants[variant] || variants.primary;
const sizeClass = sizes[size] || sizes.md;
const classes = [variantClass, sizeClass, className].filter(Boolean).join(" ");
---

{
  href ? (
    <a href={href} class={classes} id={id} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} id={id} {...rest}>
      <slot />
    </button>
  )
}
