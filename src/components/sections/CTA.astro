---
import { Image } from "astro:assets";
import Card from "@/components/ui/Card.astro";
import Section from "@/components/sections/Section.astro";
import Button from "@/components/ui/Button.astro";

import propImg from "@/assets/pics/cta.webp";
---

<Section>
  <div
    class="cta-parallax relative flex items-center justify-center w-screen left-1/2 right-1/2 -translate-x-1/2 min-h-[750px] md:min-h-screen rounded-[0] overflow-hidden mt-[80px] mb-[120px]"
    data-parallax
  >
    <Image
      src={propImg}
      alt="Background"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/40"></div>
    <div
      class="relative z-10 w-full max-w-2xl px-6 py-16 md:py-0 flex flex-col items-center justify-center gap-6 text-white min-h-[inherit]"
    >
      <h2
        class="text-3xl text-center md:text-4xl font-medium drop-shadow-lg text-white shadow-text gsap-fade-up"
      >
        Más de una década de experiencia garantizando proyectos eléctricos de
        vanguardia. <br />¿Cuál es tu próximo reto?
      </h2>
      <Button 
        variant="secondary"
        size="md" 
        href="#contact" 
        class="mt-2 gsap-fade-up"
        >
        Envíanos tu Proyecto
      </Button>
    </div>
  </div>
</Section>
<style>
  .shadow-text {
    text-shadow:
      0 4px 24px #000,
      0 2px 8px #000,
      0 1px 2px #000;
  }
</style>
